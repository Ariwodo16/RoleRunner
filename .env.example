# RoleRunner Environment Variables
# Copy this file to .env.local and fill in your actual values

# ====================
# EMAIL INTEGRATION (Choose one)
# ====================

# Option 1: Resend (Recommended - easiest)
# Sign up at https://resend.com and get your API key
RESEND_API_KEY=re_your_api_key_here

# Your email address to receive notifications
NOTIFICATION_EMAIL=your.email@gmail.com

# ====================
# GOOGLE SHEETS INTEGRATION (Choose one method)
# ====================

# Method 1: Apps Script Web App (Recommended - easiest)
# Follow GOOGLE_SHEETS_SETUP.md to create and deploy
GOOGLE_SHEETS_WEB_APP_URL=https://script.google.com/macros/s/YOUR_DEPLOYMENT_ID/exec

# Method 2: Google Sheets API (Advanced)
# Get API key from Google Cloud Console
# GOOGLE_SHEETS_API_KEY=your_google_api_key_here
# GOOGLE_SPREADSHEET_ID=your_spreadsheet_id_here

# ====================
# OPTIONAL INTEGRATIONS
# ====================

# SendGrid (alternative to Resend)
# SENDGRID_API_KEY=your_sendgrid_key_here

# Slack Notifications (webhook URL)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ====================
# PRODUCTION SETTINGS
# ====================

# Your verified domain for sending emails (Resend)
# FROM_EMAIL=hello@yourdomain.com

# ====================
# NOTES
# ====================
# 1. Copy this file to .env.local (not .env)
# 2. Never commit .env.local to git (it's in .gitignore)
# 3. Restart your dev server after changing env variables
# 4. In production (Vercel/Netlify), add these in the dashboard
